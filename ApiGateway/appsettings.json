{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "Jwt": {
    "SecretKey": "T13nd4D3p4rtam3nt4l-S3cr3tK3y-2024!@#$",
    "Issuer": "ApiGateway.TiendaDepartamental",
    "Audience": "TiendaDepartamental.Clientes",
    "ExpiresInMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Microservices": {
    "Catalogo":    "http://ms-catalogo:8081",
    "Clientes":    "http://ms-clientes:8082",
    "Ordenes":     "http://ms-ordenes:8083",
    "Pagos":       "http://ms-pagos:8084",
    "Envios":      "http://ms-envios:8085",
    "Promociones": "http://ms-promociones:8086"
  },
  "ReverseProxy": {
    "Clusters": {
      "cluster-catalogo": {
        "Destinations": {
          "dest1": { "Address": "http://ms-catalogo:8081" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "cluster-clientes": {
        "Destinations": {
          "dest1": { "Address": "http://ms-clientes:8082" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "cluster-ordenes": {
        "Destinations": {
          "dest1": { "Address": "http://ms-ordenes:8083" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "cluster-pagos": {
        "Destinations": {
          "dest1": { "Address": "http://ms-pagos:8084" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "cluster-envios": {
        "Destinations": {
          "dest1": { "Address": "http://ms-envios:8085" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "cluster-promociones": {
        "Destinations": {
          "dest1": { "Address": "http://ms-promociones:8086" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    },
    "Routes": {
      "route-catalogo-public": {
        "ClusterId": "cluster-catalogo",
        "Match": {
          "Path": "/api/catalogo/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Transforms": [ { "PathPattern": "/api/catalogo/{**catch-all}" } ],
        "Metadata": { "RateLimiterPolicy": "public" }
      },
      "route-catalogo-admin": {
        "ClusterId": "cluster-catalogo",
        "AuthorizationPolicy": "AdminOnly",
        "Match": {
          "Path": "/api/catalogo/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        },
        "Transforms": [ { "PathPattern": "/api/catalogo/{**catch-all}" } ],
        "Metadata": { "RateLimiterPolicy": "authenticated" }
      },
      "route-clientes-registro": {
        "ClusterId": "cluster-clientes",
        "Match": {
          "Path": "/api/clientes/registro",
          "Methods": [ "POST" ]
        },
        "Transforms": [ { "PathPattern": "/api/clientes/registro" } ],
        "Metadata": { "RateLimiterPolicy": "strict" }
      },
      "route-clientes-login": {
        "ClusterId": "cluster-clientes",
        "Match": {
          "Path": "/api/clientes/login",
          "Methods": [ "POST" ]
        },
        "Transforms": [ { "PathPattern": "/api/clientes/login" } ],
        "Metadata": { "RateLimiterPolicy": "strict" }
      },
      "route-clientes-auth": {
        "ClusterId": "cluster-clientes",
        "AuthorizationPolicy": "AuthenticatedUser",
        "Match": {
          "Path": "/api/clientes/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/clientes/{**catch-all}" } ],
        "Metadata": { "RateLimiterPolicy": "authenticated" }
      },
      "route-ordenes": {
        "ClusterId": "cluster-ordenes",
        "AuthorizationPolicy": "AuthenticatedUser",
        "Match": {
          "Path": "/api/ordenes/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/ordenes/{**catch-all}" } ],
        "Metadata": { "RateLimiterPolicy": "authenticated" }
      },
      "route-pagos": {
        "ClusterId": "cluster-pagos",
        "AuthorizationPolicy": "AuthenticatedUser",
        "Match": {
          "Path": "/api/pagos/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/pagos/{**catch-all}" } ],
        "Metadata": { "RateLimiterPolicy": "strict" }
      },
      "route-envios": {
        "ClusterId": "cluster-envios",
        "AuthorizationPolicy": "AuthenticatedUser",
        "Match": {
          "Path": "/api/envios/{**catch-all}"
        },
        "Transforms": [ { "PathPattern": "/api/envios/{**catch-all}" } ],
        "Metadata": { "RateLimiterPolicy": "authenticated" }
      },
      "route-promociones-public": {
        "ClusterId": "cluster-promociones",
        "Match": {
          "Path": "/api/promociones/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Transforms": [ { "PathPattern": "/api/promociones/{**catch-all}" } ],
        "Metadata": { "RateLimiterPolicy": "public" }
      },
      "route-promociones-admin": {
        "ClusterId": "cluster-promociones",
        "AuthorizationPolicy": "AdminOnly",
        "Match": {
          "Path": "/api/promociones/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        },
        "Transforms": [ { "PathPattern": "/api/promociones/{**catch-all}" } ],
        "Metadata": { "RateLimiterPolicy": "authenticated" }
      }
    }
  }
}