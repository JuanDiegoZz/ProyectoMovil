{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Information"
    }
  },
  "Microservices": {
    "Catalogo":    "http://localhost:8081",
    "Clientes":    "http://localhost:8082",
    "Ordenes":     "http://localhost:8083",
    "Pagos":       "http://localhost:8084",
    "Envios":      "http://localhost:8085",
    "Promociones": "http://localhost:8086"
  },
  "ReverseProxy": {
    "Clusters": {
      "cluster-catalogo":    { "Destinations": { "dest1": { "Address": "http://localhost:8081" } } },
      "cluster-clientes":    { "Destinations": { "dest1": { "Address": "http://localhost:8082" } } },
      "cluster-ordenes":     { "Destinations": { "dest1": { "Address": "http://localhost:8083" } } },
      "cluster-pagos":       { "Destinations": { "dest1": { "Address": "http://localhost:8084" } } },
      "cluster-envios":      { "Destinations": { "dest1": { "Address": "http://localhost:8085" } } },
      "cluster-promociones": { "Destinations": { "dest1": { "Address": "http://localhost:8086" } } }
    }
  }
}